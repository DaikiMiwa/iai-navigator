{
  "manifest_version": 3,
  "name": "Safari Keyboard Navigation Extension",
  "version": "0.1.0",
  "description": "A small Safari extension for link hints and keyboard page movement.",
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "switch-tab-previous": {
      "suggested_key": {
        "default": "Alt+Shift+J",
        "mac": "Alt+Shift+J"
      },
      "description": "Switch to the tab on the left"
    },
    "switch-tab-next": {
      "suggested_key": {
        "default": "Alt+Shift+K",
        "mac": "Alt+Shift+K"
      },
      "description": "Switch to the tab on the right"
    }
  },
  "permissions": ["tabs"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "js": ["hints.js", "help.js", "scroll-surface.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "host_permissions": ["http://*/*", "https://*/*", "file:///*"]
}
